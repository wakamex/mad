{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mad.local/schemas/action.schema.json",
  "title": "ActionSubmission",
  "type": "object",
  "required": ["tick_id", "command"],
  "properties": {
    "tick_id": {"type": "string"},
    "command": {"type": "string"},
    "target": {"type": "string"},
    "option": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "theory": {"type": "string", "maxLength": 512},
    "submission_id": {"type": "string", "maxLength": 128}
  },
  "additionalProperties": false
}
